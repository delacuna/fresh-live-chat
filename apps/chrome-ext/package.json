{
  "name": "@fresh-chat-keeper/chrome-ext",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm run build:popup && pnpm run build:content && pnpm run build:background",
    "build:popup": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "dev": "vite build --watch --config vite.content.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fresh-chat-keeper/judgment-engine": "workspace:*",
    "@fresh-chat-keeper/knowledge-base": "workspace:*",
    "@fresh-chat-keeper/shared": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
