{
  "name": "@spoilershield/chrome-ext",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm run build:scripts && pnpm run build:popup",
    "build:scripts": "vite build --config vite.scripts.config.ts",
    "build:popup": "vite build",
    "dev": "vite build --watch --config vite.scripts.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@spoilershield/knowledge-base": "workspace:*",
    "@spoilershield/shared": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
