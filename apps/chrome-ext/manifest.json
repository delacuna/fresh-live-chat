{
  "manifest_version": 3,
  "name": "SpoilerShield",
  "version": "0.1.0",
  "description": "ゲーム配信のチャットからネタバレをフィルタします",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "https://spoilershield-proxy.playnicelab.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SpoilerShield"
  }
}
